# Lunch Wheel — environment template. Copy to `.env` and fill in.
# (Real .env files are gitignored.)

# ── Core ───────────────────────────────────────────────────────────────────
# MySQL / TiDB connection string (e.g. mysql://user:pass@host:4000/lunchwheel)
DATABASE_URL=
# Secret used to sign the HS256 session JWT. Use a long random value.
JWT_SECRET=
# Arbitrary app identifier baked into the session token (any non-empty string).
VITE_APP_ID=lunch-wheel
# Public origin of the deployed app, e.g. https://lunch.example.com
# REQUIRED in production (used to build the Google OAuth redirect_uri).
APP_ORIGIN=
# Node env. Set to "production" when deployed.
NODE_ENV=development

# ── Google sign-in (self-hosted auth) ──────────────────────────────────────
# Create an OAuth 2.0 "Web application" client in Google Cloud Console.
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/google/callback   (local dev)
#   https://<your-domain>/api/auth/google/callback    (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The owner's identity = "google:<sub>" (the Google subject id of your account).
# Easiest: sign in once, then read your row's openId from the users table.
OWNER_OPEN_ID=

# ── Legacy / Manus (no longer required when self-hosting) ───────────────────
# OAUTH_SERVER_URL=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
